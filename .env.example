# ===== Environment Variables for OpenClaw Extensions =====
#
# Copy this file to .env and fill in the values.
# These are OPTIONAL — most config goes in openclaw.json.
# Env vars here are only for values that channel.ts reads from process.env.

# --- Grok Image Generation (for /grok_draw command) ---
GROK2API_BASE_URL=http://127.0.0.1:18001/v1
GROK2API_KEY=your_grok_api_key_here

# --- Bangumi (fallback, prefer plugins.entries.bangumi.config.token in openclaw.json) ---
# BANGUMI_TOKEN=your_bangumi_token_here

# --- HuggingFace Mirror (needed in China for model downloads) ---
HF_ENDPOINT=https://hf-mirror.com
