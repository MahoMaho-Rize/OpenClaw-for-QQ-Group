{
  "id": "rag",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "siliconflowApiKey": {
        "type": "string",
        "description": "SiliconFlow API Key for embedding model"
      },
      "embeddingModel": {
        "type": "string",
        "description": "Embedding model name (default: BAAI/bge-m3)"
      },
      "chromaUrl": {
        "type": "string",
        "description": "ChromaDB HTTP server URL (default: http://127.0.0.1:8100)"
      },
      "chromaCollection": {
        "type": "string",
        "description": "ChromaDB collection name (default: moegirl_wiki)"
      },
      "dataDir": {
        "type": "string",
        "description": "Data directory for logs (default: auto)"
      }
    }
  }
}
